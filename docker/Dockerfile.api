FROM maven:3.9-eclipse-temurin-17-alpine AS build
WORKDIR /app
COPY mall-api/pom.xml mall-api/pom.xml
COPY mall-api/src mall-api/src
RUN mvn -f mall-api/pom.xml -DskipTests package -q

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/mall-api/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
